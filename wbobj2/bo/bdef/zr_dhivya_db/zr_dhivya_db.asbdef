managed implementation in class ZBP_R_DHIVYA_DB unique;
strict ( 2 );
with draft;
extensible;
define behavior for ZR_DHIVYA_DB alias ZrDhivyaDb
persistent table zdhivya_db
extensible
draft table zdhivya_db_d
etag master LocalLastChangedAt
lock master total etag LastChangedAt
authorization master ( global )
{
  field ( readonly )
  UUID,
  LocalCreatedBy,
  LocalCreatedAt,
  LocalLastChangedBy,
  LocalLastChangedAt,
  LastChangedAt;

  field ( numbering : managed )
  UUID;


  create;
  update;
  delete;

  draft action Activate optimized;
  draft action Discard;
  draft action Edit;
  draft action Resume;
  draft determine action Prepare;

  determination GetCities on save { field airportFromID, AirportToID; }
  validation CheckOriginDestination on save { create; field AirportFromID, AirportToID; }

  validation CheckCarrierID on save { create; field CarrierID; }

  validation CheckSemanticKey on save { create; update; }
  mapping for zdhivya_db corresponding extensible
    {
      UUID               = UUID;
      CarrierID          = CARRIER_ID;
      ConnectionID       = CONNECTION_ID;
      AirportFromID      = AIRPORT_FROM_ID;
      CityFrom           = CITY_FROM;
      CountryFrom        = COUNTRY_FROM;
      AirportToID        = AIRPORT_TO_ID;
      CityTo             = CITY_TO;
      CountryTo          = COUNTRY_TO;
      LocalCreatedBy     = LOCAL_CREATED_BY;
      LocalCreatedAt     = LOCAL_CREATED_AT;
      LocalLastChangedBy = LOCAL_LAST_CHANGED_BY;
      LocalLastChangedAt = LOCAL_LAST_CHANGED_AT;
      LastChangedAt      = LAST_CHANGED_AT;
    }

}